{
  "name": "3dgoldai",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend:wait\"",
    "dev:backend": "cd backend && ../.venv/bin/python -m uvicorn app.main:app --reload",
    "dev:frontend": "npm run dev -w frontend",
  "dev:frontend:wait": "wait-on --http-method GET http://127.0.0.1:8000/health/server && npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "preview": "npm run preview -w frontend",
    "start": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "lint": "npm run lint -w frontend && npm run lint -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.2"
  }
}
