REDIS_HOST=your-redis-host
REDIS_PASSWORD=your-redis-password

GEMINI_API_KEY=your-gemini-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
GROQ_API_KEY=your-groq-api-key
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ── Anti-block: YouTube transcript proxy ──
# Option A (recommended): Webshare rotating residential proxy
# Sign up at webshare.io → buy "Residential" package → copy creds from dashboard
YT_WEBSHARE_PROXY_USERNAME=
YT_WEBSHARE_PROXY_PASSWORD=
# Option B: Any generic HTTP/SOCKS proxy
# Format: http://user:pass@host:port or socks5://user:pass@host:port
YT_PROXY_URL=
# Cookie file for yt-dlp audio downloads (Netscape format, export from browser)
YT_COOKIES_FILE=
# Seconds between transcript fetches (default: 5, backoff multiplied on blocks)
YT_TRANSCRIPT_DELAY_SECONDS=5

