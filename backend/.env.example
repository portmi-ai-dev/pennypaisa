REDIS_HOST=your-redis-host
REDIS_PORT=6380
REDIS_USERNAME=default
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_SSL_FALLBACK=true

NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLE_GROUNDING=true

# Optional: comma-separated YouTube channel URLs for the hourly video-id cron
YT_CHANNEL_URLS=https://www.youtube.com/channel/UCRvqjQPSeaWn-uEx-w0XOIg,https://www.youtube.com/channel/UCanAtEpNJ2H9otfsgcLlu0w,https://www.youtube.com/channel/UCwTu6kD2igaLMpxswtcdxlg
